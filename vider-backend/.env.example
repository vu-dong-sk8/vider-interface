# PostgreSQL (bỏ qua để dùng SQLite fallback)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vider_db

# Model LLM (GGUF via llama.cpp)
LLM_REPO=Qwen/Qwen2.5-3B-Instruct-GGUF
LLM_FILE=qwen2.5-3b-instruct-q4_k_m.gguf
LLM_CTX=4096

# Tavily Web Search API (free: 1000 searches/month)
# Get your key at: https://tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# CORS origins (phân cách bằng dấu phẩy)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server port
PORT=8000
